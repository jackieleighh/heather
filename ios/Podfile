# Uncomment this line to define a global platform for your project
platform :ios, '16.0'

# CocoaPods analytics sends network stats synchronously affecting flutter build latency.
ENV['COCOAPODS_DISABLE_STATS'] = 'true'

# Xcode 26 uses project object version 70 which xcodeproj gem doesn't support yet.
# Patch the mapping until xcodeproj releases a fix.
require 'xcodeproj'
updated = Xcodeproj::Constants::COMPATIBILITY_VERSION_BY_OBJECT_VERSION.dup
updated[70] = 'Xcode 26.0'
Xcodeproj::Constants.send(:remove_const, :COMPATIBILITY_VERSION_BY_OBJECT_VERSION)
Xcodeproj::Constants.const_set(:COMPATIBILITY_VERSION_BY_OBJECT_VERSION, updated.freeze)

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'Generated.xcconfig'), __FILE__)
  unless File.exist?(generated_xcode_build_settings_path)
    raise "#{generated_xcode_build_settings_path} must exist. If you're running pod install manually, make sure flutter pub get is executed first"
  end

  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/FLUTTER_ROOT\=(.*)/)
    return matches[1].strip if matches
  end
  raise "FLUTTER_ROOT not found in #{generated_xcode_build_settings_path}. Try deleting Generated.xcconfig, then run flutter pub get"
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)

flutter_ios_podfile_setup

# Firebase 12.12.x module visibility bug: FirebaseSharedSwift types not
# visible to FirebaseFirestore under Xcode 26. Fixed in 12.13.0.
# Remove once FlutterFire ships firebase_core with Firebase iOS SDK >= 12.13.0.
$FirebaseSDKVersion = '12.13.0'

target 'Runner' do
  use_frameworks!

  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
  target 'RunnerTests' do
    inherit! :search_paths
  end
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)
    target.build_configurations.each do |config|
      # Xcode 26 Swift 6 fix: generate stable .swiftinterface files so
      # cross-module type resolution works for pure-Swift pods
      # (FirebaseSharedSwift, workmanager_apple, etc.)
      config.build_settings['BUILD_LIBRARY_FOR_DISTRIBUTION'] = 'YES'
      swift_flags = config.build_settings['OTHER_SWIFT_FLAGS'] || '$(inherited)'
      unless swift_flags.include?('-no-verify-emitted-module-interface')
        config.build_settings['OTHER_SWIFT_FLAGS'] =
          "#{swift_flags} -no-verify-emitted-module-interface"
      end
    end
  end
end
